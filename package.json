{
  "name": "@cptl/electron",
  "version": "1.1.0",
  "private": true,
  "description": "Cyphers loading screen overlay",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "electron": "32.3.3",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.cptl.cyphers-overlay",
    "productName": "CPTL 사이퍼즈 오버레이",
    "asar": true,
    "files": [
      "src/**/*",
      "assets/**/*",
      "overlay.html",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  }
}
